<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gediz Biyokütle</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green:     #2d5a27;
      --green-mid: #4a7c41;
      --green-lt:  #e8f2e6;
      --accent:    #a8c96e;
      --text:      #1a1f18;
      --muted:     #5a6357;
      --border:    #d4dfd2;
      --white:     #ffffff;
      --bg:        #f7faf6;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background: var(--white);
      line-height: 1.65;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 5%; height: 68px;
      background: rgba(255,255,255,0.96);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(8px);
    }
    .logo {
      font-family: 'DM Serif Display', serif;
      font-size: 1.25rem;
      color: var(--green);
      text-decoration: none;
      letter-spacing: -.02em;
    }
    .logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      text-decoration: none; font-size: .875rem; font-weight: 500;
      color: var(--muted); transition: color .2s;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--green); }
    .nav-cta {
      background: var(--green); color: var(--white);
      border: none; padding: .5rem 1.2rem; border-radius: 6px;
      font-size: .875rem; font-weight: 500; cursor: pointer;
      text-decoration: none; transition: background .2s;
    }
    .nav-cta:hover { background: var(--green-mid); }

    /* ── PAGE SECTIONS ── */
    .page { display: none; padding-top: 68px; min-height: 100vh; }
    .page.active { display: block; }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(135deg, var(--green) 0%, var(--green-mid) 60%, #6b9e5e 100%);
      color: var(--white);
      padding: 7rem 5% 5rem;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='28'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .hero-inner { position: relative; max-width: 700px; }
    .hero-tag {
      display: inline-block;
      background: rgba(168,201,110,.25); color: var(--accent);
      font-size: .75rem; font-weight: 600; letter-spacing: .08em;
      text-transform: uppercase; padding: .3rem .8rem; border-radius: 20px;
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.2rem, 5vw, 3.4rem);
      line-height: 1.15; margin-bottom: 1.25rem;
    }
    .hero h1 em { font-style: italic; color: var(--accent); }
    .hero p {
      font-size: 1.05rem; opacity: .85; max-width: 560px; margin-bottom: 2rem;
    }
    .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn-primary {
      background: var(--white); color: var(--green);
      padding: .75rem 1.6rem; border-radius: 8px;
      font-weight: 600; font-size: .9rem; text-decoration: none;
      transition: transform .15s, box-shadow .15s;
      border: 2px solid var(--white);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,.2); }
    .btn-outline {
      border: 2px solid rgba(255,255,255,.5); color: var(--white);
      padding: .75rem 1.6rem; border-radius: 8px;
      font-weight: 500; font-size: .9rem; text-decoration: none;
      transition: border-color .2s;
    }
    .btn-outline:hover { border-color: var(--white); }

    /* ── STATS BAR ── */
    .stats-bar {
      background: var(--bg); border-bottom: 1px solid var(--border);
      display: flex; justify-content: center; flex-wrap: wrap; gap: 0;
    }
    .stat {
      padding: 1.8rem 3rem;
      border-right: 1px solid var(--border);
      text-align: center;
    }
    .stat:last-child { border-right: none; }
    .stat-num {
      font-family: 'DM Serif Display', serif;
      font-size: 1.8rem; color: var(--green); display: block;
    }
    .stat-label { font-size: .8rem; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }

    /* ── SECTION ── */
    .section { padding: 5rem 5%; }
    .section-label {
      font-size: .75rem; font-weight: 600; letter-spacing: .1em;
      text-transform: uppercase; color: var(--green-mid);
      margin-bottom: .75rem;
    }
    .section-title {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem); color: var(--text);
      margin-bottom: 1rem; max-width: 600px; line-height: 1.25;
    }
    .section-lead {
      font-size: 1rem; color: var(--muted); max-width: 600px;
      margin-bottom: 3rem; line-height: 1.75;
    }

    /* ── CARD GRID ── */
    .card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap: 1.25rem; }
    .card {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 12px; padding: 2rem;
      transition: box-shadow .2s, transform .2s;
    }
    .card:hover { box-shadow: 0 8px 24px rgba(45,90,39,.1); transform: translateY(-3px); }
    .card-icon {
      width: 44px; height: 44px; border-radius: 10px;
      background: var(--green-lt); display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; margin-bottom: 1.25rem;
    }
    .card h3 { font-size: 1rem; font-weight: 600; margin-bottom: .5rem; }
    .card p { font-size: .875rem; color: var(--muted); line-height: 1.6; }

    /* ── DIVIDER ── */
    .divider { border: none; border-top: 1px solid var(--border); margin: 0 5%; }

    /* ── BIZ KIMIZ PAGE ── */
    .page-hero {
      background: var(--bg); border-bottom: 1px solid var(--border);
      padding: 4rem 5% 3rem;
    }
    .page-hero .section-label { margin-bottom: .5rem; }
    .page-hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem;
    }
    .page-hero p { font-size: 1rem; color: var(--muted); max-width: 640px; line-height: 1.75; }

    .two-col {
      display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;
      align-items: start;
    }
    @media (max-width: 768px) {
      .two-col { grid-template-columns: 1fr; gap: 2rem; }
      .nav-links { display: none; }
      .stat { padding: 1.2rem 1.5rem; }
    }

    .value-list { list-style: none; margin-top: 1.5rem; }
    .value-list li {
      display: flex; gap: .75rem; align-items: flex-start;
      padding: .75rem 0; border-bottom: 1px solid var(--border);
      font-size: .9rem;
    }
    .value-list li:last-child { border-bottom: none; }
    .value-list .vi {
      width: 28px; height: 28px; flex-shrink: 0;
      background: var(--green-lt); border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: .9rem; margin-top: 1px;
    }
    .value-list strong { display: block; font-weight: 600; color: var(--text); }
    .value-list span { color: var(--muted); }

    /* ── SERVICES SECTION ── */
    .service-row {
      display: grid; grid-template-columns: 1fr 1fr;
      border: 1px solid var(--border); border-radius: 12px;
      overflow: hidden; margin-bottom: 1.25rem;
    }
    @media (max-width: 640px) { .service-row { grid-template-columns: 1fr; } }
    .service-content { padding: 2.5rem; }
    .service-content h3 { font-size: 1.1rem; font-weight: 600; margin-bottom: .75rem; }
    .service-content p { font-size: .9rem; color: var(--muted); line-height: 1.7; }
    .service-tag {
      display: inline-block; margin-bottom: .75rem;
      font-size: .75rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: .07em; color: var(--green-mid);
    }
    .service-bg {
      background: var(--green-lt);
      display: flex; align-items: center; justify-content: center;
      font-size: 3rem; min-height: 140px;
    }

    /* ── CONTACT PAGE ── */
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1.3fr; gap: 3rem;
      align-items: start;
    }
    @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; } }
    .contact-info-block { margin-bottom: 1.5rem; }
    .contact-info-block label {
      display: block; font-size: .75rem; text-transform: uppercase;
      letter-spacing: .08em; color: var(--muted); margin-bottom: .35rem; font-weight: 600;
    }
    .contact-info-block a, .contact-info-block p {
      font-size: 1rem; color: var(--text); text-decoration: none; font-weight: 500;
    }
    .contact-info-block a:hover { color: var(--green); }

    .map-container {
      border-radius: 12px; overflow: hidden;
      border: 1px solid var(--border); height: 360px;
    }
    .map-container iframe { width: 100%; height: 100%; border: none; }

    /* ── FOOTER ── */
    footer {
      background: var(--green); color: rgba(255,255,255,.75);
      padding: 2.5rem 5%;
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 1rem;
      font-size: .85rem;
    }
    footer .foot-logo {
      font-family: 'DM Serif Display', serif;
      color: var(--white); font-size: 1.1rem;
    }
    footer a { color: rgba(255,255,255,.6); text-decoration: none; }
    footer a:hover { color: var(--white); }

    /* ── HIGHLIGHT BOX ── */
    .highlight-box {
      background: var(--green); color: var(--white);
      border-radius: 14px; padding: 3rem 3.5rem;
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 1.5rem; margin-top: 3rem;
    }
    .highlight-box h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.5rem; margin-bottom: .4rem;
    }
    .highlight-box p { opacity: .8; font-size: .9rem; }
  </style>
</head>
